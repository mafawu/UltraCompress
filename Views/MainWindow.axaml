<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:UltraCompress.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:UltraCompress.Models"
        xmlns:dd="using:Avalonia.Input"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="820"
        x:Class="UltraCompress.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ProBatch Compressor"
        TransparencyLevelHint="AcrylicBlur"
        Background="#0f172a"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

	<Window.Resources>
		<!-- Tailwind Color Palette Mapping -->
		<Color x:Key="Slate950">#020617</Color>
		<Color x:Key="Slate900">#0f172a</Color>
		<Color x:Key="Slate850">#14213a</Color>
		<Color x:Key="Slate800">#1e293b</Color>
		<Color x:Key="Slate700">#334155</Color>
		<Color x:Key="Slate400">#94a3b8</Color>
		<Color x:Key="Blue600">#2563eb</Color>
		<Color x:Key="Green500">#22c55e</Color>
    <Color x:Key="AccentBase">#0f766e</Color>
    <!-- Teal-700 -->
    <Color x:Key="AccentHover">#0d9488</Color>
    <!-- Teal-600 -->
    <Color x:Key="AccentPress">#115e59</Color>
    <!-- Teal-800 -->
    <Color x:Key="TextHighlight">#2dd4bf</Color>
    <!-- Teal-400 (文字高亮用) -->

    <!-- 新的深蓝色系 (更沉稳，不刺眼) -->
    <Color x:Key="DeepBlueBase">#1d4ed8</Color>
    <!-- Blue-700: 主色 -->
    <Color x:Key="DeepBlueHover">#2563eb</Color>
    <!-- Blue-600: 悬浮稍微亮一点 -->
    <Color x:Key="DeepBluePress">#1e40af</Color>
    <!-- Blue-800: 按下变深 -->

    <Color x:Key="GreenDark">#16a34a</Color>
    <!-- Green-600: 稍微暗一点的绿色 -->

    <SolidColorBrush x:Key="BgDark" Color="{StaticResource Slate900}"/>
    <SolidColorBrush x:Key="BgPanel" Color="{StaticResource Slate800}"/>
    <SolidColorBrush x:Key="TextMuted" Color="{StaticResource Slate400}"/>
    <SolidColorBrush x:Key="AccentBlue" Color="{StaticResource DeepBlueBase}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentBase}"/>
		<SolidColorBrush x:Key="CardBackground" Color="#1f2a40"/>
	</Window.Resources>

	<Window.Styles>
    <!-- 全局滚动条尺寸 -->
    <Style Selector="ScrollBar:vertical">
	  <Setter Property="Width" Value="16"/>
	  <Setter Property="MinWidth" Value="16"/>
	</Style>
	<Style Selector="ScrollBar:horizontal">
	  <Setter Property="Height" Value="16"/>
	  <Setter Property="MinHeight" Value="16"/>
	</Style>

    <!-- 滚动条轨道 -->
    <Style Selector="ScrollBar">
      <Setter Property="Background" Value="#1a2335"/>
    </Style>

    <!-- 滚动条滑块（未交互） -->
    <Style Selector="ScrollBar /template/ Thumb">
      <Setter Property="Background" Value="#334155"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="MinWidth" Value="10"/>
      <Setter Property="MinHeight" Value="32"/>
    </Style>

    <!-- 滚动条滑块（鼠标悬浮） -->
    <Style Selector="ScrollBar /template/ Thumb:pointerover">
      <Setter Property="Background" Value="#475569"/>
    </Style>

    <!-- 滚动条滑块（按下/拖动中） -->
    <Style Selector="ScrollBar /template/ Thumb:pressed">
      <Setter Property="Background" Value="#64748b"/>
    </Style>

    <!-- 滚动条箭头按钮：隐藏 -->
    <Style Selector="ScrollBar /template/ RepeatButton">
      <Setter Property="IsVisible" Value="False"/>
      <Setter Property="Width" Value="0"/>
      <Setter Property="Height" Value="0"/>
    </Style>

    <!-- 收折面板头部按钮 -->
    <Style Selector="ToggleButton.SectionHeader">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Foreground" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="ToggleButton.SectionHeader:pointerover">
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ToggleButton.SectionHeader:checked">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="ToggleButton.SectionHeader:pointerover:checked">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="Button.Primary">
      <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
      <Setter Property="Foreground" Value="#f0fdfa"/>
      <!-- 极淡的青白色 -->
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.Primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <!-- 手动引用 AccentHover 颜色资源 -->
      <Setter Property="Background" Value="{DynamicResource AccentHover}"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.Primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AccentPress}"/>
      <Setter Property="Foreground" Value="#ccfbf1"/>
    </Style>

    <!-- 2. Secondary Button (保持深灰，通用) -->
    <Style Selector="Button.Secondary">
      <Setter Property="Background" Value="#283548"/>
      <Setter Property="Foreground" Value="#cbd5e1"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#334155"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.Secondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#334155"/>
      <Setter Property="BorderBrush" Value="#475569"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.Secondary:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#1e293b"/>
      <Setter Property="Foreground" Value="#94a3b8"/>
    </Style>

    <!-- 3. Ghost Button (保持通用) -->
    <Style Selector="Button.Ghost">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.Ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#1e293b"/>
      <Setter Property="Foreground" Value="#cbd5e1"/>
    </Style>

    <!-- 4. 禁用状态 (保持通用) -->
    <Style Selector="Button:disabled /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="#334155"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="#475569"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="ToggleButton.TabButton">
      <Setter Property="Background" Value="{StaticResource Slate950}"/>
      <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="16,16,0,0"/>
      <Setter Property="Padding" Value="18,10"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.2"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
          <BrushTransition Property="Foreground" Duration="0:0:0.2"/>
        </Transitions>
      </Setter>
      <Setter Property="Template">
        <ControlTemplate TargetType="ToggleButton">
          <Border x:Name="RootBorder"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}">
            <StackPanel>
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                Foreground="{TemplateBinding Foreground}"/>
              <Border x:Name="AccentBar"
                      Height="3"
                      Margin="12,6,12,10"
                      CornerRadius="2"
                      Background="Transparent"/>
            </StackPanel>
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ToggleButton.TabButton:pointerover">
      <Setter Property="Background" Value="#1e293b"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="8,8,0,0"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ToggleButton.TabButton:checked">
      <Setter Property="Background" Value="{StaticResource CardBackground}"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="8,8,0,0"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ToggleButton.TabButton:checked /template/ Border#AccentBar">
      <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
      <Setter Property="Height" Value="4"/>
      <Setter Property="Margin" Value="12,6,12,8"/>
    </Style>

  </Window.Styles>

	<Grid RowDefinitions="40, *, 32">

		<!-- 1. Custom Title Bar -->
		<Grid Grid.Row="0" Background="{StaticResource Slate950}" ColumnDefinitions="Auto, *, Auto" PointerPressed="OnTitleBarPointerPressed">
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
				<TextBlock Text="⚡ ProBatch Compressor" Foreground="#3b82f6" FontWeight="Bold" VerticalAlignment="Center"/>
				<Border Background="{StaticResource Slate900}" CornerRadius="4" Margin="10,0,0,0" Padding="6,2">
					<TextBlock Text="v1.0.1" FontSize="10" Foreground="{StaticResource TextMuted}"/>
				</Border>
			</StackPanel>

			<StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
				<ToggleButton Content="🎬 视频压缩" Classes="TabButton" Command="{Binding SwitchViewCommand}" CommandParameter="Video" IsChecked="{Binding IsVideoView, Mode=OneWay}"/>
				<ToggleButton Content="🖼 图片压缩" Classes="TabButton" Command="{Binding SwitchViewCommand}" CommandParameter="Image" IsChecked="{Binding IsImageView, Mode=OneWay}"/>
			</StackPanel>

			<StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0" Spacing="6">
				<Button Click="OnMinimizeClick" Width="32" Height="24" Classes="Primary" BorderThickness="0" CornerRadius="4">
					<TextBlock Text="—" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
				</Button>
				<Button Click="OnMaximizeRestoreClick" Width="32" Height="24" Classes="Primary" BorderThickness="0" CornerRadius="4">
					<Path x:Name="MaxRestoreIcon" Width="14" Height="14" Stroke="White" StrokeThickness="1.5" Stretch="Uniform" Data="M3,3 H13 V13 H3 Z"/>
				</Button>
				<Button Click="OnCloseClick" Width="32" Height="24" Classes="Primary" BorderThickness="0" CornerRadius="4">
					<TextBlock Text="×" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
				</Button>
			</StackPanel>
		</Grid>

		<!-- 2. Main Workspace -->
		<Grid Grid.Row="1" Background="{StaticResource BgPanel}">
			<Grid ColumnDefinitions="*, 320" IsVisible="{Binding CurrentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter='Video'}">

				<!-- B. Center Content Area -->
				<Grid Grid.Column="0" Background="{StaticResource BgPanel}">
                 <Border x:Name="VideoDropSurface" Margin="20" Background="{StaticResource CardBackground}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="20" Padding="0">
					 <Grid RowDefinitions="56, 36, *" Grid.IsSharedSizeScope="True" DragDrop.AllowDrop="True" DragDrop.DragOver="OnFilesDragOver" DragDrop.Drop="OnFilesDrop" DragDrop.DragLeave="OnFilesDragLeave">
          <!-- Toolbar -->
          <Border Grid.Row="0" BorderBrush="{StaticResource Slate700}" BorderThickness="0,0,0,1" Background="{StaticResource CardBackground}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0" Spacing="10">
              <Button Command="{Binding AddFilesCommand}" Content="➕ 添加文件" Classes="Primary" Foreground="White" CornerRadius="4"/>
              <Rectangle Width="1" Height="20" Fill="{StaticResource Slate700}"/>
              <Button Command="{Binding StartBatchCommand}" Content="▶ 开始压缩" Classes="Primary" Foreground="White" CornerRadius="4"/>
              <Button Command="{Binding CancelBatchCommand}" Content="⏹ 取消任务" Classes="Primary" Foreground="{StaticResource TextMuted}" CornerRadius="4" Margin="0,0,0,0" IsEnabled="{Binding IsProcessing}"/>
              <Button Command="{Binding ClearCompletedCommand}" Content="🗑 清理已完成" Classes="Primary" Foreground="White" CornerRadius="4" Margin="10,0,0,0"/>
              <Button Command="{Binding ClearAllCommand}" Content="🧹 清理所有" Classes="Primary" Foreground="White" CornerRadius="4" Margin="10,0,0,0"/>
              <Button Command="{Binding ReplaceOutputsCommand}" Content="♻ 替换原片" Classes="Primary" Foreground="White" CornerRadius="4" Margin="10,0,0,0"/>
            </StackPanel>
          </Border>

			<!-- Table Header -->
			<Grid Grid.Row="1" Background="#131c30">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="8*"/>
					<ColumnDefinition Width="4*"/>
					<ColumnDefinition Width="16*"/>
					<ColumnDefinition Width="10*"/>
					<ColumnDefinition Width="12*"/>
					<ColumnDefinition Width="8*"/>
					<ColumnDefinition Width="10*"/>
					<ColumnDefinition Width="10*"/>
					<ColumnDefinition Width="13*"/>
					<ColumnDefinition Width="10*"/>
					<ColumnDefinition Width="8*"/>
					<ColumnDefinition Width="5*"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Column="0" Text="预览" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
				<Button Grid.Column="1"
						Content="#"
						Command="{Binding SortVideoColumnCommand}"
						CommandParameter="index"
						Foreground="{StaticResource TextMuted}"
						FontSize="12"
						Background="Transparent"
						BorderThickness="0"
						HorizontalAlignment="Stretch"
						HorizontalContentAlignment="Center"
						Cursor="Hand"
						Padding="0"/>
				<Button Grid.Column="2"
						Content="文件名"
						Command="{Binding SortVideoColumnCommand}"
						CommandParameter="name"
						Foreground="{StaticResource TextMuted}"
						FontSize="12"
						Background="Transparent"
						BorderThickness="0"
						HorizontalAlignment="Stretch"
						HorizontalContentAlignment="Left"
						Padding="10,0"
						Cursor="Hand"/>
				<Button Grid.Column="3"
						Content="原始大小"
						Command="{Binding SortVideoColumnCommand}"
						CommandParameter="size"
						Foreground="{StaticResource TextMuted}"
						FontSize="12"
						Background="Transparent"
						BorderThickness="0"
						HorizontalAlignment="Stretch"
						HorizontalContentAlignment="Right"
						Padding="0"
						Cursor="Hand"/>
				<Button Grid.Column="4"
						Content="码率"
						Command="{Binding SortVideoColumnCommand}"
						CommandParameter="bitrate"
						Foreground="{StaticResource TextMuted}"
						FontSize="12"
						Background="Transparent"
						BorderThickness="0"
						HorizontalAlignment="Stretch"
						HorizontalContentAlignment="Center"
						Padding="0"
						Cursor="Hand"/>
				<Button Grid.Column="5"
						Content="分辨率"
						Command="{Binding SortVideoColumnCommand}"
						CommandParameter="resolution"
						Foreground="{StaticResource TextMuted}"
						FontSize="12"
						Background="Transparent"
						BorderThickness="0"
						HorizontalAlignment="Stretch"
						HorizontalContentAlignment="Center"
						Padding="0"
						Cursor="Hand"/>
				<Button Grid.Column="6"
						Content="已用时间"
						Command="{Binding SortVideoColumnCommand}"
						CommandParameter="elapsed"
						Foreground="{StaticResource TextMuted}"
						FontSize="12"
						Background="Transparent"
						BorderThickness="0"
						HorizontalAlignment="Stretch"
						HorizontalContentAlignment="Center"
						Padding="0"
						Cursor="Hand"/>
				<Button Grid.Column="7"
						Content="剩余时间"
						Command="{Binding SortVideoColumnCommand}"
						CommandParameter="remaining"
						Foreground="{StaticResource TextMuted}"
						FontSize="12"
						Background="Transparent"
						BorderThickness="0"
						HorizontalAlignment="Stretch"
						HorizontalContentAlignment="Center"
						Padding="0"
						Cursor="Hand"/>
				<Button Grid.Column="8"
						Content="进度"
						Command="{Binding SortVideoColumnCommand}"
						CommandParameter="progress"
						Foreground="{StaticResource TextMuted}"
						FontSize="12"
						Background="Transparent"
						BorderThickness="0"
						HorizontalAlignment="Stretch"
						HorizontalContentAlignment="Center"
						Padding="0"
						Cursor="Hand"/>
				<Button Grid.Column="9"
						Content="预估大小"
						Command="{Binding SortVideoColumnCommand}"
						CommandParameter="expected"
						Foreground="{StaticResource TextMuted}"
						FontSize="12"
						Background="Transparent"
						BorderThickness="0"
						HorizontalAlignment="Stretch"
						HorizontalContentAlignment="Center"
						Padding="0"
						Cursor="Hand"/>
				<TextBlock Grid.Column="10" Text="打开" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
				<TextBlock Grid.Column="11" Text="删除" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
			</Grid>

          <!-- File List -->
          <ScrollViewer Grid.Row="2" Background="#111a2b">
            <ItemsControl ItemsSource="{Binding Files}">
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="models:VideoFile">
                  <Border BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="0,4">
				<Grid>
					<Grid.ColumnDefinitions>
				<ColumnDefinition Width="8*"/>
				<ColumnDefinition Width="4*"/>
				<ColumnDefinition Width="16*"/>
				<ColumnDefinition Width="10*"/>
				<ColumnDefinition Width="12*"/>
				<ColumnDefinition Width="8*"/>
				<ColumnDefinition Width="10*"/>
				<ColumnDefinition Width="10*"/>
				<ColumnDefinition Width="13*"/>
				<ColumnDefinition Width="10*"/>
				<ColumnDefinition Width="8*"/>
				<ColumnDefinition Width="5*"/>
					</Grid.ColumnDefinitions>
				      <Border Grid.Column="0" Width="64" Height="36" Background="#1b2437" CornerRadius="8" Margin="12,0" HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="True">
				        <Grid>
				          <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNotNull}}"/>
				          <TextBlock Text="🎬" FontSize="18" Foreground="#475569" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNull}}"/>
				        </Grid>
				      </Border>

				      <TextBlock Grid.Column="1" Text="{Binding Index}" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" HorizontalAlignment="Center"/>

			      <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center" Margin="0,0,20,0">
			        <TextBlock Text="{Binding Name}"
														 Foreground="#e2e8f0"
														 TextTrimming="CharacterEllipsis"
															 MaxWidth="200"
														 ToolTip.Tip="{Binding FullPath}"/>
																<TextBlock Text="{Binding FullPath}"
																				 Foreground="{StaticResource TextMuted}"
																				 FontSize="10"
																				 TextTrimming="CharacterEllipsis"
																				 MaxWidth="200"/>
			      </StackPanel>
				      <TextBlock Grid.Column="3" Text="{Binding OriginalSize, StringFormat='{}{0} MB'}" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas"/>
				      <TextBlock Grid.Column="4" Text="{Binding Metadata.BitrateKbps, StringFormat='{}{0:0} kbps', TargetNullValue='--'}" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas"/>
				      <TextBlock Grid.Column="5" Text="{Binding ResolutionText}" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas"/>
				      <TextBlock Grid.Column="6" Text="{Binding Elapsed, StringFormat='{}{0:hh\\:mm\\:ss}', TargetNullValue='--:--:--'}" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas"/>
				      <TextBlock Grid.Column="7" Text="{Binding Remaining, StringFormat='{}{0:hh\\:mm\\:ss}', TargetNullValue='--:--:--'}" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas"/>
				      <ProgressBar Grid.Column="8"
                                   Value="{Binding Progress}"
                                   Minimum="0"
                                   Maximum="100"
                                   Height="6"
                                   CornerRadius="3"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Stretch"
                                   Margin="6,0"
                                   MinWidth="0"
                                   Foreground="{StaticResource AccentBlue}"
                                   Background="#334155"/>

                      <TextBlock Grid.Column="9" Text="{Binding ExpectedSize, StringFormat='{}{0} MB', TargetNullValue='---'}" Foreground="#4ade80" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas"/>
                      <Button Grid.Column="10" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenOutputPathCommand}" CommandParameter="{Binding}" Content="📂" Background="Transparent" Foreground="White" IsEnabled="{Binding CanOpen}" HorizontalAlignment="Center"/>
                      <Button Grid.Column="11" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RemoveFileCommand}" CommandParameter="{Binding}"
                              Content="🗑" Background="Transparent" Foreground="#ef4444" IsVisible="{Binding CanDelete}" HorizontalAlignment="Center"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

		  <!-- Loading overlay when adding files -->
		  <Border Grid.RowSpan="3" Background="#CC0f172a" IsVisible="{Binding IsAddingFiles}" ZIndex="10" CornerRadius="20">
		    <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="#1f2937" Padding="30" CornerRadius="12">
		      <StackPanel Spacing="12">
		        <TextBlock Text="正在导入文件..." Foreground="White" FontSize="16" HorizontalAlignment="Center"/>
		        <ProgressBar IsIndeterminate="True" Width="200" Height="6" Foreground="{StaticResource AccentBlue}" Background="#334155"/>
		        <TextBlock Text="请稍候，正在读取元数据" Foreground="{StaticResource TextMuted}" FontSize="12" HorizontalAlignment="Center"/>
		      </StackPanel>
		    </Border>
		  </Border>
		</Grid>

				</Border>
			</Grid>

			<!-- C. Right Inspector Panel -->
			<Grid Grid.Column="1" Background="{StaticResource BgPanel}">
				<Border Margin="10,20,20,20" Background="{StaticResource CardBackground}" BorderBrush="{StaticResource Slate800}" BorderThickness="1" CornerRadius="16">
					<Grid RowDefinitions="50, *, 40" Margin="0">
					<Border Grid.Row="0" BorderBrush="{StaticResource Slate800}" BorderThickness="0,0,0,1">
						<TextBlock Text="参数配置 (Settings)" VerticalAlignment="Center" Margin="20,0" FontWeight="Bold" Foreground="#cbd5e1"/>
					</Border>

					<ScrollViewer Grid.Row="1">
					<StackPanel Margin="20" Spacing="8">

					<!-- ════════ 视频编码 ════════ -->
					<ToggleButton IsChecked="{Binding IsVideoEncodingExpanded}" Classes="SectionHeader">
						<Grid ColumnDefinitions="Auto, Auto, *, Auto">
							<TextBlock Text="▼" Foreground="{StaticResource AccentBlue}" FontSize="10" VerticalAlignment="Center" IsVisible="{Binding IsVideoEncodingExpanded}"/>
							<TextBlock Text="▶" Foreground="{StaticResource TextMuted}" FontSize="10" VerticalAlignment="Center" IsVisible="{Binding IsVideoEncodingCollapsed}"/>
							<TextBlock Grid.Column="1" Text=" 视频编码" Foreground="{StaticResource AccentBlue}" FontWeight="Bold" FontSize="12" Margin="4,0,0,0"/>
							<TextBlock Grid.Column="3" Text="{Binding VideoEncodingSummary}" Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
						</Grid>
					</ToggleButton>
					<StackPanel Spacing="6" IsVisible="{Binding IsVideoEncodingExpanded}">
						<StackPanel Spacing="5">
							<TextBlock Text="编码器 (Encoder)" Foreground="{StaticResource TextMuted}" FontSize="12"/>
							<ComboBox SelectedIndex="{Binding SelectedEncoderIndex}" HorizontalAlignment="Stretch" Background="{StaticResource Slate800}" Foreground="White">
									<ComboBoxItem>H.264 (x264)</ComboBoxItem>
									<ComboBoxItem>H.265 (x265)</ComboBoxItem>
								<ComboBoxItem>NVENC H.264 (GPU)</ComboBoxItem>
									<ComboBoxItem>NVENC H.265 (GPU)</ComboBoxItem>
								</ComboBox>
							</StackPanel>
							<StackPanel Spacing="5">
								<Grid ColumnDefinitions="*, Auto">
							<TextBlock Text="码率模式" Foreground="{StaticResource TextMuted}" FontSize="12"/>
							<ComboBox Grid.Column="1" SelectedIndex="{Binding SelectedBitrateMode}" Background="{StaticResource Slate800}" Foreground="White">
								<ComboBoxItem>自定义</ComboBoxItem>
								<ComboBoxItem>倍数</ComboBoxItem>
								<ComboBoxItem>原始码率</ComboBoxItem>
							</ComboBox>
						</Grid>
						<StackPanel Spacing="5" IsVisible="{Binding IsCustomBitrateMode}">
							<Grid ColumnDefinitions="*, Auto">
								<TextBlock Text="目标码率 (Mbps)" Foreground="{StaticResource TextMuted}" FontSize="12"/>
								<TextBlock Text="{Binding TargetBitrateMbps, StringFormat='{}{0:0.#} Mbps'}" Foreground="White" Grid.Column="1"/>
							</Grid>
							<Slider Minimum="0.1" Maximum="10" Value="{Binding TargetBitrateMbps}" TickFrequency="0.5" IsSnapToTickEnabled="True"/>
							<Grid ColumnDefinitions="*, *">
								<TextBlock Text="低码率 / 小体积" FontSize="10" Foreground="#475569"/>
								<TextBlock Text="高码率 / 高画质" FontSize="10" Foreground="#475569" HorizontalAlignment="Right" Grid.Column="1"/>
							</Grid>
						</StackPanel>
						<StackPanel Spacing="5" IsVisible="{Binding IsMultiplierBitrateMode}">
							<TextBlock Text="倍数选择" Foreground="{StaticResource TextMuted}" FontSize="12"/>
							<ComboBox ItemsSource="{Binding BitrateMultiplierOptions}" SelectedItem="{Binding TargetBitrateMultiplier, Mode=TwoWay}" Background="{StaticResource Slate800}" Foreground="White">
								<ComboBox.ItemTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding StringFormat='{}{0:0.##}x'}"/>
									</DataTemplate>
								</ComboBox.ItemTemplate>
							</ComboBox>
							<TextBlock Text="输出码率将按照源文件码率乘以所选倍数估算。若缺少源码率信息则退回自定义数值。" TextWrapping="Wrap" Foreground="#475569" FontSize="10"/>
						</StackPanel>
						<TextBlock Text="将保持原始码率" Foreground="#475569" FontSize="10" IsVisible="{Binding IsOriginalBitrateMode}"/>
					</StackPanel>
					</StackPanel>

					<Separator Background="{StaticResource Slate800}"/>

					<!-- ════════ 导入过滤 ════════ -->
					<ToggleButton IsChecked="{Binding IsImportFilterExpanded}" Classes="SectionHeader">
						<Grid ColumnDefinitions="Auto, Auto, *, Auto">
							<TextBlock Text="▼" Foreground="{StaticResource AccentBlue}" FontSize="10" VerticalAlignment="Center" IsVisible="{Binding IsImportFilterExpanded}"/>
							<TextBlock Text="▶" Foreground="{StaticResource TextMuted}" FontSize="10" VerticalAlignment="Center" IsVisible="{Binding IsImportFilterCollapsed}"/>
							<TextBlock Grid.Column="1" Text=" 导入过滤" Foreground="{StaticResource AccentBlue}" FontWeight="Bold" FontSize="12" Margin="4,0,0,0"/>
							<TextBlock Grid.Column="3" Text="{Binding ImportFilterSummary}" Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
						</Grid>
					</ToggleButton>
					<StackPanel Spacing="5" IsVisible="{Binding IsImportFilterExpanded}">
						<Grid ColumnDefinitions="*, Auto">
							<TextBlock Text="最低码率 (kbps)" Foreground="{StaticResource TextMuted}" FontSize="12"/>
							<TextBlock Text="{Binding MinBitrateFilterKbps, StringFormat='{}{0} kbps'}" Foreground="White" Grid.Column="1"/>
						</Grid>
						<Slider Minimum="0" Maximum="10000" Value="{Binding MinBitrateFilterKbps}" TickFrequency="500" IsSnapToTickEnabled="True"/>
						<Grid ColumnDefinitions="*, *">
							<TextBlock Text="0 = 不限制" FontSize="10" Foreground="#475569"/>
							<TextBlock Text="大码率 / 高画质" FontSize="10" Foreground="#475569" HorizontalAlignment="Right" Grid.Column="1"/>
						</Grid>
						<TextBlock Text="导入文件时，码率低于此值的视频将被自动跳过" TextWrapping="Wrap" Foreground="#475569" FontSize="10"/>
					</StackPanel>

					<Separator Background="{StaticResource Slate800}"/>

					<!-- ════════ 分辨率 ════════ -->
					<ToggleButton IsChecked="{Binding IsResolutionExpanded}" Classes="SectionHeader">
						<Grid ColumnDefinitions="Auto, Auto, *, Auto">
							<TextBlock Text="▼" Foreground="{StaticResource AccentBlue}" FontSize="10" VerticalAlignment="Center" IsVisible="{Binding IsResolutionExpanded}"/>
							<TextBlock Text="▶" Foreground="{StaticResource TextMuted}" FontSize="10" VerticalAlignment="Center" IsVisible="{Binding IsResolutionCollapsed}"/>
							<TextBlock Grid.Column="1" Text=" 分辨率" Foreground="{StaticResource AccentBlue}" FontWeight="Bold" FontSize="12" Margin="4,0,0,0"/>
							<TextBlock Grid.Column="3" Text="{Binding ResolutionSummary}" Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
						</Grid>
					</ToggleButton>
					<StackPanel Spacing="6" IsVisible="{Binding IsResolutionExpanded}">
						<TextBlock Text="分辨率模式" Foreground="{StaticResource TextMuted}" FontSize="12"/>
						<ComboBox SelectedIndex="{Binding SelectedResolutionMode}" HorizontalAlignment="Stretch" Background="{StaticResource Slate800}" Foreground="White">
							<ComboBoxItem>Original (源分辨率)</ComboBoxItem>
							<ComboBoxItem>1080p</ComboBoxItem>
							<ComboBoxItem>720p</ComboBoxItem>
							<ComboBoxItem>自定义</ComboBoxItem>
							<ComboBoxItem>按倍数缩放</ComboBoxItem>
						</ComboBox>
						<StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding IsCustomResolutionMode}">
								<StackPanel>
									<TextBlock Text="宽度" Foreground="{StaticResource TextMuted}" FontSize="11"/>
									<TextBox Width="80" Text="{Binding CustomWidth, Mode=TwoWay}" Background="{StaticResource Slate800}" Foreground="White" BorderBrush="{StaticResource Slate700}"/>
								</StackPanel>
								<StackPanel>
									<TextBlock Text="高度" Foreground="{StaticResource TextMuted}" FontSize="11"/>
									<TextBox Width="80" Text="{Binding CustomHeight, Mode=TwoWay}" Background="{StaticResource Slate800}" Foreground="White" BorderBrush="{StaticResource Slate700}"/>
								</StackPanel>
						</StackPanel>
						<StackPanel Spacing="2" IsVisible="{Binding IsCustomResolutionMode}">
							<TextBlock Text="{Binding ReferenceResolutionText, StringFormat='源分辨率：{0}'}" Foreground="{StaticResource TextMuted}" FontSize="11"/>
							<TextBlock Text="{Binding TargetResolutionText, StringFormat='目标输出：{0}'}" Foreground="{StaticResource AccentBlue}" FontSize="11"/>
						</StackPanel>
						<StackPanel Spacing="5" IsVisible="{Binding IsScaleResolutionMode}">
							<TextBlock Text="缩放倍数" Foreground="{StaticResource TextMuted}" FontSize="11"/>
							<ComboBox ItemsSource="{Binding ScaleOptions}" SelectedItem="{Binding ScaleFactor, Mode=TwoWay}" HorizontalAlignment="Stretch" Background="{StaticResource Slate800}" Foreground="White">
								<ComboBox.ItemTemplate>
									<DataTemplate>
										<TextBlock Text="{Binding StringFormat='{}{0:0.##}x'}"/>
									</DataTemplate>
								</ComboBox.ItemTemplate>
							</ComboBox>
							<StackPanel Spacing="2" Margin="0,6,0,0">
								<TextBlock Text="{Binding ReferenceResolutionText, StringFormat='源分辨率：{0}'}" Foreground="{StaticResource TextMuted}" FontSize="11"/>
								<TextBlock Text="{Binding TargetResolutionText, StringFormat='目标输出：{0}'}" Foreground="{StaticResource AccentBlue}" FontSize="11"/>
							</StackPanel>
						</StackPanel>
					</StackPanel>

					<Separator Background="{StaticResource Slate800}"/>

					<!-- ════════ 并行编码 ════════ -->
					<ToggleButton IsChecked="{Binding IsParallelEncodingExpanded}" Classes="SectionHeader">
						<Grid ColumnDefinitions="Auto, Auto, *, Auto">
							<TextBlock Text="▼" Foreground="{StaticResource AccentBlue}" FontSize="10" VerticalAlignment="Center" IsVisible="{Binding IsParallelEncodingExpanded}"/>
							<TextBlock Text="▶" Foreground="{StaticResource TextMuted}" FontSize="10" VerticalAlignment="Center" IsVisible="{Binding IsParallelEncodingCollapsed}"/>
							<TextBlock Grid.Column="1" Text=" 并行编码" Foreground="{StaticResource AccentBlue}" FontWeight="Bold" FontSize="12" Margin="4,0,0,0"/>
							<TextBlock Grid.Column="3" Text="{Binding ParallelEncodingSummary}" Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
						</Grid>
					</ToggleButton>
					<StackPanel Spacing="5" IsVisible="{Binding IsParallelEncodingExpanded}">
						<Grid ColumnDefinitions="*, Auto">
							<TextBlock Text="最大并发数" Foreground="{StaticResource TextMuted}" FontSize="12"/>
							<TextBlock Grid.Column="1" Text="{Binding MaxConcurrentEncodes, StringFormat='{}{0} 路'}" Foreground="White"/>
						</Grid>
						<Slider Minimum="1" Maximum="6" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding MaxConcurrentEncodes}" IsEnabled="{Binding IsNotProcessing}"/>
						<Grid ColumnDefinitions="*, *">
							<TextBlock Text="保守（低CPU）" FontSize="10" Foreground="#475569"/>
							<TextBlock Text="激进（高吞吐）" FontSize="10" Foreground="#475569" HorizontalAlignment="Right" Grid.Column="1"/>
						</Grid>
						<TextBlock Text="转码开始后不可修改" FontSize="10" Foreground="{StaticResource TextMuted}"/>
					</StackPanel>

					</StackPanel>
					</ScrollViewer>
					</Grid>
				</Border>
			</Grid>
		</Grid>

		<!-- IMAGE VIEW FULL PANEL -->
		<Grid IsVisible="{Binding CurrentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter='Image'}" ColumnDefinitions="*, 320">
			<!-- Image workspace -->
            <Grid Grid.Column="0" Background="{StaticResource BgPanel}">
			 <Border x:Name="ImageDropSurface" Margin="20" Background="{StaticResource CardBackground}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="20" Padding="0">
					<Grid RowDefinitions="56, *" Grid.IsSharedSizeScope="True">
						<!-- Toolbar -->
						<Border Grid.Row="0" BorderBrush="{StaticResource Slate700}" BorderThickness="0,0,0,1" Background="{StaticResource CardBackground}" Padding="0">
							<StackPanel Orientation="Horizontal" VerticalAlignment="Center"  Margin="20,0" Spacing="10">
								<Button Command="{Binding AddImagesCommand}" Content="➕ 导入图片" Classes="Primary" Foreground="White" CornerRadius="4"/>
								<Rectangle Width="1" Height="20" Fill="{StaticResource Slate700}"/>
								<Button Command="{Binding StartImageCompressionCommand}" Content="▶ 开始压缩" Classes="Primary" Foreground="White" CornerRadius="4"/>
								<Button Command="{Binding CancelImageCompressionCommand}" Content="⏹ 取消任务" Classes="Primary" Foreground="{StaticResource TextMuted}" CornerRadius="4" IsEnabled="{Binding IsImageProcessing}"/>
								<Button Command="{Binding ClearImageCompletedCommand}" Content="🗑 清理已完成" Classes="Primary" Foreground="White" CornerRadius="4" Margin="10,0,0,0"/>
								<Button Command="{Binding ClearImageAllCommand}" Content="🧹 清理所有" Classes="Primary" Foreground="White" CornerRadius="4" Margin="10,0,0,0"/>
								<Button Command="{Binding ReplaceImageOutputsCommand}" Content="♻ 替换原图" Classes="Primary" Foreground="White" CornerRadius="4" Margin="10,0,0,0"/>
								<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0" Spacing="8">
									<TextBlock Text="整体进度" Foreground="{StaticResource TextMuted}" FontSize="11"/>
									<ProgressBar Value="{Binding ImageGlobalProgress}" Minimum="0" Maximum="100" Width="160" Height="6" CornerRadius="3" Foreground="{StaticResource AccentBlue}" Background="#334155"/>
									<TextBlock Text="{Binding ImageGlobalProgress, StringFormat='{}{0:0}%'}" Foreground="{StaticResource TextMuted}" FontSize="11"/>
									<TextBlock Text="{Binding ImageProgressCountText}" Foreground="{StaticResource TextMuted}" FontSize="11"/>
								</StackPanel>
							</StackPanel>
						</Border>

            <Grid Grid.Row="1" Grid.IsSharedSizeScope="True" DragDrop.AllowDrop="True" DragDrop.DragOver="OnFilesDragOver" DragDrop.Drop="OnFilesDrop" DragDrop.DragLeave="OnFilesDragLeave">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <Border Grid.Row="0" Background="#131c30" BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="0,8" MinHeight="40">
                <Grid Margin="10,0,20,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" MinWidth="44"/>
                    <ColumnDefinition Width="12*"/>
                    <ColumnDefinition Width="5*" MinWidth="80"/>
                    <ColumnDefinition Width="5*" MinWidth="80"/>
                    <ColumnDefinition Width="5*" MinWidth="60"/>
                    <ColumnDefinition Width="5*" MinWidth="80"/>
                    <ColumnDefinition Width="4*" MinWidth="40"/>
                    <ColumnDefinition Width="4*" MinWidth="40"/>
                  </Grid.ColumnDefinitions>

                  <Button Grid.Column="0" Content="#"
						  Command="{Binding SortImageColumnCommand}" CommandParameter="index"
						  HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
						  Foreground="#94a3b8" FontWeight="Bold" FontSize="12"
						  Background="Transparent" BorderThickness="0" Padding="0"/>
				  <Button Grid.Column="1" Content="文件名"
                          Command="{Binding SortImageColumnCommand}" CommandParameter="name"
                          HorizontalAlignment="Left" HorizontalContentAlignment="Left"
                          Foreground="#94a3b8" FontWeight="Bold" FontSize="12"
                          Background="Transparent" BorderThickness="0" Padding="5,0"/>
                  <Button Grid.Column="2" Content="原始大小"
                          Command="{Binding SortImageColumnCommand}" CommandParameter="original"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                          Foreground="#94a3b8" FontWeight="Bold" FontSize="12"
                          Background="Transparent" BorderThickness="0" Padding="0"/>
                  <Button Grid.Column="3" Content="压缩后"
                          Command="{Binding SortImageColumnCommand}" CommandParameter="compressed"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                          Foreground="#94a3b8" FontWeight="Bold" FontSize="12"
                          Background="Transparent" BorderThickness="0" Padding="0"/>
                  <Button Grid.Column="4" Content="节省"
                          Command="{Binding SortImageColumnCommand}" CommandParameter="reduction"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                          Foreground="#94a3b8" FontWeight="Bold" FontSize="12"
                          Background="Transparent" BorderThickness="0" Padding="0"/>
                  <Button Grid.Column="5" Content="状态"
                          Command="{Binding SortImageColumnCommand}" CommandParameter="status"
                          HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                          Foreground="#94a3b8" FontWeight="Bold" FontSize="12"
                          Background="Transparent" BorderThickness="0" Padding="0"/>
                  <TextBlock Grid.Column="6" Text="打开"
                             Foreground="#94a3b8" FontWeight="Bold" FontSize="12"
                             VerticalAlignment="Center" HorizontalAlignment="Center"/>
                  <TextBlock Grid.Column="7" Text="操作"
                             Foreground="#94a3b8" FontWeight="Bold" FontSize="12"
                             VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
              </Border>

              <ListBox Grid.Row="1"
                       ItemsSource="{Binding ImageFiles}"
                       SelectedItem="{Binding SelectedImage}"
                       SelectionMode="Single"
                       BorderThickness="0"
                       Background="Transparent">

                <ListBox.Styles>
                  <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="0"/>
                  </Style>
                </ListBox.Styles>

                <ListBox.ItemTemplate>
                  <DataTemplate DataType="models:ImageFile">
                    <Border BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="10,4">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="3*"/>
                          <ColumnDefinition Width="12*"/>
                          <ColumnDefinition Width="5*"/>
                          <ColumnDefinition Width="5*"/>
                          <ColumnDefinition Width="5*"/>
                          <ColumnDefinition Width="5*"/>
                          <ColumnDefinition Width="4*"/>
                          <ColumnDefinition Width="4*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding Index}" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas"/>

						<StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center" Margin="0,0,10,0">
                          <TextBlock Text="{Binding FileName}" Foreground="#e2e8f0" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding FullPath}"/>
                          <TextBlock Text="{Binding FullPath}" Foreground="{StaticResource TextMuted}" FontSize="10" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <TextBlock Grid.Column="2" Text="{Binding OriginalSizeText}" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas"/>
						<TextBlock Grid.Column="3" Text="{Binding NewSizeText}" Foreground="#e5e7eb" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas"/>
						<TextBlock Grid.Column="4" Text="{Binding ReductionText}" Foreground="#4ade80" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas"/>
						<Border Grid.Column="5" Background="#1e293b" CornerRadius="8" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0">
                          <TextBlock Text="{Binding Status}" Foreground="{Binding StatusColor}" FontSize="12" HorizontalAlignment="Center"/>
                        </Border>
                        <Button Grid.Column="6" Content="📂" Background="Transparent" BorderThickness="0" Foreground="White"
                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenCompressedImageCommand}"
                                CommandParameter="{Binding}" Cursor="Hand"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                IsEnabled="{Binding CompressedPath, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                        <StackPanel Grid.Column="7" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                          <Button Content="🗑" Background="Transparent" BorderThickness="0" Foreground="#f87171"
                                  Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RemoveImageCommand}"
                                  CommandParameter="{Binding}" Cursor="Hand"/>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                          IsHitTestVisible="False" Spacing="10"
                          IsVisible="{Binding ImageFiles.Count, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=0}">
                <TextBlock Text="📂" FontSize="40" HorizontalAlignment="Center" Foreground="#334155"/>
                <TextBlock Foreground="#64748b" FontSize="14" Text="拖拽或点击上方按钮导入图片"/>
              </StackPanel>
            </Grid>

						<!-- Loading overlay for image imports -->
						<Border Grid.RowSpan="3" Background="#CC0f172a" IsVisible="{Binding IsAddingImages}" ZIndex="10" CornerRadius="20">
							<Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="#1f2937" Padding="30" CornerRadius="12">
								<StackPanel Spacing="12">
									<TextBlock Text="正在导入图片..." Foreground="White" FontSize="16" HorizontalAlignment="Center"/>
									<ProgressBar IsIndeterminate="True" Width="200" Height="6" Foreground="{StaticResource AccentBlue}" Background="#334155"/>
									<TextBlock Text="请稍候，正在读取文件信息" Foreground="{StaticResource TextMuted}" FontSize="12" HorizontalAlignment="Center"/>
								</StackPanel>
							</Border>
						</Border>
					</Grid>
				</Border>
			</Grid>

			<!-- Image settings panel -->
			<Grid Grid.Column="1" Background="{StaticResource BgPanel}">
				<Border Margin="10,20,20,20" Background="{StaticResource CardBackground}" BorderBrush="{StaticResource Slate800}" BorderThickness="1" CornerRadius="16" Padding="0">
					<Grid RowDefinitions="Auto,*" Margin="0">
						<Border Grid.Row="0" BorderBrush="{StaticResource Slate800}" BorderThickness="0,0,0,1" Padding="20,0">
							<TextBlock Text="图片参数" VerticalAlignment="Center" FontWeight="Bold" Foreground="#cbd5e1" FontSize="16"/>
						</Border>
						<ScrollViewer Grid.Row="1">
							<StackPanel Margin="20" Spacing="16">
								<TextBlock Text="基础设置" Foreground="{StaticResource AccentBlue}" FontWeight="Bold" FontSize="12"/>
								<StackPanel Spacing="6">
									<TextBlock Text="目标格式" Foreground="{StaticResource TextMuted}" FontSize="12"/>
									<ComboBox ItemsSource="{Binding ImageFormats}" SelectedItem="{Binding SelectedImageFormat}" Background="{StaticResource Slate800}" Foreground="White"/>
								</StackPanel>
								<StackPanel Spacing="3">
									<Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
										<TextBlock Text="输出质量（越大质量越高）" Foreground="{StaticResource TextMuted}" FontSize="12"/>
										<TextBlock Grid.Column="1" Text="{Binding ImageQuality, StringFormat='{}{0}%'}" Foreground="White"/>
									</Grid>
									<Slider Minimum="10" Maximum="100" Value="{Binding ImageQuality}" TickFrequency="5" IsSnapToTickEnabled="True"/>
								</StackPanel>

								<Separator Background="{StaticResource Slate800}"/>

								<TextBlock Text="缩放" Foreground="{StaticResource AccentBlue}" FontWeight="Bold" FontSize="12"/>
								<StackPanel Spacing="6">
									<CheckBox Content="启用缩放" IsChecked="{Binding ResizeImages}" Foreground="White"/>
									<StackPanel Spacing="4" IsVisible="{Binding ResizeImages}">
										<Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="8">
											<TextBlock Text="宽度" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
											<TextBox Grid.Column="1" Text="{Binding ResizeWidth}" Background="{StaticResource Slate800}" Foreground="White" BorderBrush="{StaticResource Slate700}"/>
											<TextBlock Grid.Column="2" Text="px" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
										</Grid>
										<Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="8">
											<TextBlock Text="高度" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
											<TextBox Grid.Column="1" Text="{Binding ResizeHeight}" Background="{StaticResource Slate800}" Foreground="White" BorderBrush="{StaticResource Slate700}"/>
											<TextBlock Grid.Column="2" Text="px（0=自动）" Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center"/>
										</Grid>
									</StackPanel>
								</StackPanel>

								<Separator Background="{StaticResource Slate800}"/>

								<TextBlock Text="图片预览" Foreground="{StaticResource AccentBlue}" FontWeight="Bold" FontSize="12"/>
								<CheckBox Content="显示预览" IsChecked="{Binding ShowImagePreview}" Foreground="White" Margin="0,0,0,4"/>
								<Border Background="#111a2b" CornerRadius="12" Height="250" IsVisible="{Binding ShowImagePreview}">
									<Grid>
										<Image Source="{Binding SelectedImage.Thumbnail}" Stretch="Uniform" Margin="12" IsVisible="{Binding SelectedImage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
										<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6" IsVisible="{Binding SelectedImage, Converter={x:Static ObjectConverters.IsNull}}">
											<TextBlock Text="尚未选择图片" Foreground="White" FontSize="16" HorizontalAlignment="Center"/>
											<TextBlock Text="在左侧选择一项以预览" Foreground="{StaticResource TextMuted}" FontSize="12" HorizontalAlignment="Center"/>
										</StackPanel>
									</Grid>
								</Border>
								<StackPanel Spacing="4" IsVisible="{Binding ShowImagePreview}" >
									<StackPanel IsVisible="{Binding SelectedImage, Converter={x:Static ObjectConverters.IsNotNull}}">
										<TextBlock Text="{Binding SelectedImage.FileName}" Foreground="#e2e8f0" FontWeight="SemiBold" FontSize="14"/>
										<TextBlock Text="{Binding SelectedImage.FullPath}" Foreground="{StaticResource TextMuted}" FontSize="11" TextWrapping="Wrap"/>
										<TextBlock Text="{Binding SelectedImage.OriginalSizeText, StringFormat='原始体积：{0}'}" Foreground="#e2e8f0" FontSize="12"/>
										<TextBlock Text="{Binding SelectedImage.NewSizeText, StringFormat='压缩后：{0}'}" Foreground="#e2e8f0" FontSize="12"/>
									</StackPanel>
								</StackPanel>
								<StackPanel Orientation="Vertical" Spacing="10"/>
							</StackPanel>
						</ScrollViewer>
					</Grid>
				</Border>
			</Grid>
		</Grid>

			<!-- ANALYTICS VIEW FULL PANEL -->
			<Border IsVisible="{Binding CurrentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter='Analytics'}" Margin="20" Background="{StaticResource CardBackground}" CornerRadius="20">
				<StackPanel Spacing="20">
					<TextBlock Text="📈 任务分析报告" FontSize="20" FontWeight="Bold" Foreground="White"/>

					<!-- Stats Cards -->
					<Grid ColumnDefinitions="*, *, *, *" RowDefinitions="Auto" Margin="0,20">
						<Border Grid.Column="0" Background="{StaticResource Slate900}" CornerRadius="8" Padding="15" Margin="0,0,10,0">
							<StackPanel>
								<TextBlock Text="总文件数" Foreground="{StaticResource TextMuted}" FontSize="12"/>
								<TextBlock Text="{Binding TotalFilesCount}" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
							</StackPanel>
						</Border>
						<Border Grid.Column="1" Background="{StaticResource Slate900}" CornerRadius="8" Padding="15" Margin="0,0,10,0">
							<StackPanel>
								<TextBlock Text="原始总体积" Foreground="{StaticResource TextMuted}" FontSize="12"/>
								<TextBlock Text="{Binding TotalOriginalSize}" Foreground="#cbd5e1" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
							</StackPanel>
						</Border>
						<Border Grid.Column="2" Background="{StaticResource Slate900}" CornerRadius="8" Padding="15" Margin="0,0,10,0">
							<StackPanel>
								<TextBlock Text="压缩后体积" Foreground="{StaticResource TextMuted}" FontSize="12"/>
								<TextBlock Text="{Binding TotalCompressedSize}" Foreground="{StaticResource AccentBlue}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
							</StackPanel>
						</Border>
						<Border Grid.Column="3" Background="{StaticResource Slate900}" CornerRadius="8" Padding="15">
							<StackPanel>
								<TextBlock Text="节省空间" Foreground="{StaticResource TextMuted}" FontSize="12"/>
								<TextBlock Text="{Binding SavedPercent}" Foreground="{StaticResource Green500}" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
							</StackPanel>
						</Border>
					</Grid>

					<!-- Mock Chart (Native shapes) -->
					<Border Background="{StaticResource Slate900}" CornerRadius="8" Padding="20" Height="300">
						<Grid>
							<TextBlock Text="体积对比 (模拟图表)" Foreground="{StaticResource TextMuted}" VerticalAlignment="Top"/>
							<!-- Simple Visualization using Rectangles -->
							<StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Spacing="20" HorizontalAlignment="Center">
								<StackPanel VerticalAlignment="Bottom">
									<Rectangle Width="40" Height="200" Fill="#475569"/>
									<TextBlock Text="原始" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
								</StackPanel>
								<StackPanel VerticalAlignment="Bottom">
									<Rectangle Width="40" Height="120" Fill="{StaticResource AccentBlue}"/>
									<TextBlock Text="压缩后" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
								</StackPanel>
							</StackPanel>
						</Grid>
					</Border>
				</StackPanel>
			</Border>
		</Grid>

		<!-- 3. Footer / Status Bar -->
		<Border Grid.Row="2" Background="{StaticResource Slate950}" BorderBrush="{StaticResource Slate800}" BorderThickness="0,1,0,0">
			<Grid ColumnDefinitions="Auto, *, Auto" Margin="10,0">
				<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
					<StackPanel Orientation="Horizontal" Spacing="5">
						<Ellipse Width="8" Height="8" Fill="{StaticResource Green500}"/>
						<TextBlock Text="Ready" FontSize="11" Foreground="{StaticResource TextMuted}"/>
					</StackPanel>
					<Rectangle Width="1" Height="12" Fill="{StaticResource Slate800}"/>
					<TextBlock Text="{Binding CpuUsageText}" FontSize="11" Foreground="#cbd5e1" FontFamily="Consolas"/>
					<TextBlock Text="{Binding GpuUsageText}" FontSize="11" Foreground="#cbd5e1" FontFamily="Consolas"/>
					<Rectangle Width="1" Height="12" Fill="{StaticResource Slate800}"/>
					<TextBlock Text="{Binding HardwareAccelerationStatus}" FontSize="11" Foreground="{StaticResource TextMuted}"/>
					</StackPanel>
				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
					<TextBlock Text="{Binding Files.Count, StringFormat='Queue: {0} items'}" FontSize="11" Foreground="{StaticResource TextMuted}"/>
				</StackPanel>
			</Grid>
		</Border>
	</Grid>
</Window>
